/* pages/share/share.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px;
  width: 100%;
  padding-top: 100px; /* 添加顶部内边距，避开导航栏 */
}

/* 轮播图样式 */
.swiper {
  width: 100%;
  height: 250px;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.topic {
  font-size: 32rpx;
  font-weight: bold;
}

.tip-text {
  margin-top: 16rpx;
  color: #888;
  font-size: 26rpx;
  text-align: center;
}

.ai-gif {
  width: 120rpx;
  height: 120rpx;
}

.ai-tip {
  margin-top: 12rpx;
  color: #007aff;
  font-size: 28rpx;
}