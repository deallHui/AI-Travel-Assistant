.container {
  padding: 20rpx;
  background: #f5f5f5;
}

.search-bar {
  background: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.search-bar input {
  background: #f5f5f5;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.filter-section {
  display: flex;
  justify-content: space-around;
  background: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  display: flex;
  align-items: center;
}

.arrow {
  font-size: 24rpx;
  margin-left: 10rpx;
  color: #666;
}

.destination-list {
  margin-top: 20rpx;
}

.destination-card {
  background: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.destination-card image {
  width: 100%;
  height: 300rpx;
}

.destination-info {
  padding: 20rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.description {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background: #f0f0f0;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  color: #666;
}

/* AI助手入口样式 */
.ai-assistant-entry {
  margin: 30rpx 0;
}

.ai-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.ai-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.2);
}

.ai-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  animation: bounce 2s infinite;
}

.ai-content {
  flex: 1;
}

.ai-title {
  display: block;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.ai-desc {
  display: block;
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  line-height: 1.4;
}

.ai-arrow {
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

/* 动画效果 */
@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-10rpx);
  }
  60% {
    transform: translateY(-5rpx);
  }
}