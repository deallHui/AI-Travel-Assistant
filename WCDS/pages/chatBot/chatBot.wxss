/* pages/chatBot/chatBot.wxss */

.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 状态栏样式 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e0e0e0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.status-indicator {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: pulse 2s infinite;
}

.connected .status-dot {
  background-color: #4CAF50;
}

.disconnected .status-dot {
  background-color: #f44336;
}

.status-text {
  font-size: 28rpx;
  color: #666;
}

.clear-btn {
  padding: 10rpx;
  color: #999;
  font-size: 32rpx;
}

/* 聊天消息区域 */
.chat-messages {
  flex: 1;
  padding: 20rpx;
}

.message-list {
  padding-bottom: 20rpx;
}

.message-item {
  margin-bottom: 30rpx;
}

/* 机器人消息样式 */
.bot-message-container {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
}

.bot-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #2196F3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.bot-message-container .message-content {
  max-width: 70%;
  background-color: #fff;
  border-radius: 20rpx 20rpx 20rpx 8rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 用户消息样式 */
.user-message-container {
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #FF9800;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.user-message-container .message-content {
  max-width: 70%;
  background-color: #2196F3;
  color: white;
  border-radius: 20rpx 20rpx 8rpx 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 消息内容样式 */
.message-text {
  font-size: 32rpx;
  line-height: 1.5;
  word-wrap: break-word;
  white-space: pre-wrap;
}

.message-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: right;
}

.user-message-container .message-time {
  color: rgba(255,255,255,0.7);
}

/* 消息来源样式 */
.message-sources {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sources-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}

.source-tag {
  display: inline-block;
  background-color: #e3f2fd;
  color: #1976d2;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 消息元数据样式 */
.message-meta {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.confidence {
  font-size: 24rpx;
  color: #4CAF50;
  background-color: #e8f5e8;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.ai-enhanced {
  font-size: 24rpx;
  color: #FF9800;
  background-color: #fff3e0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 错误消息样式 */
.error-message .message-content {
  background-color: #ffebee;
  border-left: 6rpx solid #f44336;
}

.error-message .message-text {
  color: #d32f2f;
}

/* 加载指示器样式 */
.loading-indicator {
  margin-bottom: 30rpx;
}

.typing-indicator {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #ccc;
  margin-right: 8rpx;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.typing-dot:nth-child(2) {
  animation-delay: -0.16s;
}

.loading-text {
  color: #999;
  font-style: italic;
}

/* 输入区域样式 */
.input-area {
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  padding: 20rpx;
}

.input-container {
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 50rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 20rpx;
}

.message-input {
  flex: 1;
  font-size: 32rpx;
  background-color: transparent;
  border: none;
  outline: none;
}

.send-btn {
  background-color: #ccc;
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
  transition: all 0.3s ease;
}

.send-btn.active {
  background-color: #2196F3;
}

.send-btn:disabled {
  background-color: #ccc;
  color: #999;
}

/* 快捷问题样式 */
.quick-questions {
  margin-top: 20rpx;
}

.quick-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.quick-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-btn {
  background-color: #e3f2fd;
  color: #1976d2;
  border: 1rpx solid #bbdefb;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.quick-btn:active {
  background-color: #bbdefb;
  transform: scale(0.95);
}

/* 动画效果 */
@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.7;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes typing {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .bot-message-container .message-content,
  .user-message-container .message-content {
    max-width: 80%;
  }

  .quick-buttons {
    flex-direction: column;
  }

  .quick-btn {
    width: 100%;
    text-align: center;
  }
}
/* 可根据需要自定义样式 */