.container {
  padding: 20rpx;
}
.qa-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.qa-content {
  color: #666;
  margin-bottom: 10rpx;
}
.qa-meta {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 20rpx;
}
.comments {
  margin-top: 20rpx;
}
.comment {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 10rpx;
  margin-bottom: 10rpx;
}

/* 帖子操作区域 */
.post-actions {
  margin: 20rpx 0;
  padding: 10rpx 0;
  border-top: 1rpx solid #eee;
  border-bottom: 1rpx solid #eee;
}

/* 点赞按钮样式 */
.like-btn {
  background-color: #f5f5f5 !important;
  color: #666 !important;
  border: 1rpx solid #e0e0e0 !important;
  transition: all 0.3s ease;
}

.like-btn.liked {
  background-color: #ffe6e6 !important;
  color: #ff4757 !important;
  border: 1rpx solid #ff4757 !important;
}

.like-btn:active {
  transform: scale(0.95);
}