/* pages/comunity/comunity.wxss */
.container {
  padding: 20rpx;
}
.qa-list {
  margin-top: 20rpx;
}
.qa-item {
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx #eee;
}
.qa-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.qa-content {
  color: #666;
  margin-bottom: 10rpx;
}
.qa-meta {
  font-size: 22rpx;
  color: #999;
}
.qa-actions {
  margin-top: 10rpx;
}
.qa-actions button {
  margin-right: 10rpx;
}

/* 点赞按钮样式 */
.like-btn {
  background-color: #f5f5f5 !important;
  color: #666 !important;
  border: 1rpx solid #e0e0e0 !important;
  transition: all 0.3s ease;
}

.like-btn.liked {
  background-color: #ffe6e6 !important;
  color: #ff4757 !important;
  border: 1rpx solid #ff4757 !important;
}

.like-btn:active {
  transform: scale(0.95);
}